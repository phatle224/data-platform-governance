# ══════════════════════════════════════════════════════════════════════════════
# Data Platform Governance & Observability Stack - Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── Project ────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=gov

# ── OpenMetadata ───────────────────────────────────────────────────────────────
OPENMETADATA_VERSION=1.6.5
OPENMETADATA_PORT=8585
OPENMETADATA_ADMIN_PORT=8586

# ── MySQL (OpenMetadata metadata DB) ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=password
DB_USER=openmetadata_user
DB_USER_PASSWORD=openmetadata_password
OM_DATABASE=openmetadata_db
MYSQL_PORT=13306

# ── Elasticsearch ──────────────────────────────────────────────────────────────
ELASTICSEARCH_PORT=19200

# ── OpenMetadata Ingestion (Airflow) ───────────────────────────────────────────
INGESTION_PORT=8081

# ── Airflow (Standalone for dbt orchestration) ─────────────────────────────────
AIRFLOW_PORT=8082
AIRFLOW_POSTGRES_PORT=15434
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_FERNET_KEY=jJ/9sz0g0OHxsfxOoSfdFdmk3ysNmPRnH3TUAbz3IHA=

# ── Project A Connection Details ───────────────────────────────────────────────
# These are the container-internal addresses (via shared Docker network)
FMCG_POSTGRES_HOST=fmcg-postgres
FMCG_POSTGRES_PORT=5432
FMCG_POSTGRES_USER=postgres
FMCG_POSTGRES_PASSWORD=postgrespassword
FMCG_POSTGRES_DB=fmcg

FMCG_CLICKHOUSE_HOST=fmcg-clickhouse
FMCG_CLICKHOUSE_PORT=8123

FMCG_TRINO_HOST=fmcg-trino
FMCG_TRINO_PORT=8080
